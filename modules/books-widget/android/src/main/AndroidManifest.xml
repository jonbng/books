<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <application>
    <!-- Glance widget. This library-module receiver is merged into the app
         manifest by AGP at build time. -->
    <receiver
      android:name="dk.jonathanb.books.widget.BooksWidgetReceiver"
      android:exported="true">
      <intent-filter>
        <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
      </intent-filter>
      <meta-data
        android:name="android.appwidget.provider"
        android:resource="@xml/books_widget_info" />
    </receiver>
  </application>
</manifest>
