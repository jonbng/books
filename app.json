{
  "expo": {
    "name": "books",
    "slug": "books",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "books",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#F7F3EA",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "dk.jonathanb.books",
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F7F3EA",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "dk.jonathanb.books",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/with-android-colors",
      [
        "expo-notifications",
        {
          "color": "#C0694A"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F7F3EA",
          "dark": {
            "backgroundColor": "#1A1611"
          },
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Reading to use the camera to scan book barcodes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "995ece2f-a9e5-41c3-aea8-76ed2a204809"
      }
    }
  }
}
